# Copy to .env and fill in values. This file is safe to commit.
# .env is gitignored and loaded automatically at startup.

# Server
# NAMEHISTORY_HOST=127.0.0.1
# NAMEHISTORY_PORT=8000

# Database (SQLite path)
# NAMEHISTORY_DB_PATH=namehistory.db

# API auth for write endpoints (optional)
# NAMEHISTORY_API_KEY=
# NAMEHISTORY_ADMIN_KEY=

# Provider keys
HYPIXEL_API_KEY=

# Optional LabyMod challenge token (or solve at /api/minecraft/captcha)
# LABY_CHALLENGE_TOKEN=
# LABY_TURNSTILE_SITE_KEY=
